NODE_ENV=development
PORT=4000

# Neon PostgreSQL (pooled — for application runtime)
DATABASE_URL="postgresql://<user>:<password>@<endpoint>-pooler.<region>.aws.neon.tech/<database>?sslmode=require"

# Neon PostgreSQL (direct — for Prisma migrations only)
DIRECT_URL="postgresql://<user>:<password>@<endpoint>.<region>.aws.neon.tech/<database>?sslmode=require"

JWT_SECRET=your-secret-key-minimum-16-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-minimum-16-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:3000
