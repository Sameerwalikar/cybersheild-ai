generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────

enum Role {
  CITIZEN
  POLICE
  ORGANIZATION
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum ScanType {
  MESSAGE
  URL
  QR
  UPI
  VOICE
}

enum ScanStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum RiskLevel {
  SAFE
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ReportStatus {
  SUBMITTED
  UNDER_REVIEW
  RESOLVED
  REJECTED
}

enum ReportPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum NotificationType {
  THREAT_ALERT
  REPORT_UPDATE
  SECURITY_TIP
  SYSTEM
  SCAN_COMPLETE
}

enum NotificationSeverity {
  INFO
  WARNING
  CRITICAL
}

enum InvestigationStatus {
  ACTIVE
  MONITORING
  RESOLVED
  CRITICAL
}

enum EvidenceType {
  PHONE
  UPI
  DOMAIN
  DEVICE
  COMPLAINT
  SCREENSHOT
  AUDIO
  DOCUMENT
}

// ─────────────────────────────────────────────────────────────────────
// USER & PROFILE
// ─────────────────────────────────────────────────────────────────────

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  role         Role       @default(CITIZEN)
  isVerified   Boolean    @default(false)
  status       UserStatus @default(ACTIVE)
  lastLogin    DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  profile       Profile?
  sessions      Session[]
  scans         ThreatScan[]
  reports       ThreatReport[]
  notifications Notification[]
  auditLogs     AuditLog[]
  conversations Conversation[]

  // Police-specific
  assignedInvestigations Investigation[] @relation("AssignedOfficer")

  @@index([email])
  @@index([role, status])
  @@map("users")
}

model Profile {
  id          String  @id @default(uuid())
  userId      String  @unique
  name        String
  phone       String?
  avatar      String?
  location    String?
  bio         String?
  preferences Json    @default("{}")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

// ─────────────────────────────────────────────────────────────────────
// THREAT SCANNING & ANALYSIS
// ─────────────────────────────────────────────────────────────────────

model ThreatScan {
  id        String     @id @default(uuid())
  userId    String
  scanType  ScanType
  content   String
  status    ScanStatus @default(PENDING)
  metadata  Json?
  createdAt DateTime   @default(now())

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  analysis ThreatAnalysis?

  @@index([userId, createdAt(sort: Desc)])
  @@index([scanType, status])
  @@map("threat_scans")
}

model ThreatAnalysis {
  id             String    @id @default(uuid())
  scanId         String    @unique
  riskScore      Int
  riskLevel      RiskLevel
  summary        String
  recommendation String
  confidence     Float
  aiModel        String    @default("aegis-v1")
  processingTime Int
  createdAt      DateTime  @default(now())

  scan       ThreatScan        @relation(fields: [scanId], references: [id], onDelete: Cascade)
  indicators ThreatIndicator[]
  riskScores RiskScore?
  website    SavedWebsite?

  @@index([riskLevel])
  @@map("threat_analyses")
}

model ThreatIndicator {
  id          String @id @default(uuid())
  analysisId  String
  label       String
  severity    RiskLevel
  confidence  Float
  description String
  indicators  String[]

  analysis ThreatAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId])
  @@map("threat_indicators")
}

model RiskScore {
  id          String @id @default(uuid())
  analysisId  String @unique
  overall     Int
  contentRisk Int
  sourceRisk  Int
  patternRisk Int
  communityRisk Int
  factors     String[]
  calculatedAt DateTime @default(now())

  analysis ThreatAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@map("risk_scores")
}

model SavedWebsite {
  id           String   @id @default(uuid())
  analysisId   String   @unique
  url          String
  domain       String
  screenshotUrl String?
  sslValid     Boolean
  sslIssuer    String?
  sslExpiry    DateTime?
  redirectChain Json?
  domainAge    String?
  reputation   Int?
  lastChecked  DateTime @default(now())

  analysis ThreatAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([domain])
  @@map("saved_websites")
}

// ─────────────────────────────────────────────────────────────────────
// REPORTS
// ─────────────────────────────────────────────────────────────────────

model ThreatReport {
  id             String         @id @default(uuid())
  reportNumber   String         @unique
  userId         String
  type           String
  description    String
  scammerContact Json?
  financialLoss  Json?
  evidence       String[]
  status         ReportStatus   @default(SUBMITTED)
  priority       ReportPriority @default(MEDIUM)
  assignedTo     String?
  occurredAt     DateTime?
  resolvedAt     DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  investigation Investigation? @relation("ReportInvestigation")

  @@index([userId, createdAt(sort: Desc)])
  @@index([status, priority])
  @@index([reportNumber])
  @@map("threat_reports")
}

// ─────────────────────────────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────────────────────────────

model Notification {
  id        String               @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  severity  NotificationSeverity @default(INFO)
  isRead    Boolean              @default(false)
  actionUrl String?
  relatedId String?
  createdAt DateTime             @default(now())
  readAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt(sort: Desc)])
  @@map("notifications")
}

// ─────────────────────────────────────────────────────────────────────
// POLICE — INVESTIGATIONS & FRAUD NETWORKS
// ─────────────────────────────────────────────────────────────────────

model Investigation {
  id          String              @id @default(uuid())
  caseId      String              @unique
  title       String
  description String?
  status      InvestigationStatus @default(ACTIVE)
  confidence  Int                 @default(0)
  city        String?
  assignedTo  String?
  reportId    String?             @unique
  networkId   String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  officer  User?         @relation("AssignedOfficer", fields: [assignedTo], references: [id])
  report   ThreatReport? @relation("ReportInvestigation", fields: [reportId], references: [id])
  network  FraudNetwork? @relation(fields: [networkId], references: [id])
  evidence Evidence[]

  @@index([status, city])
  @@index([assignedTo])
  @@map("investigations")
}

model FraudNetwork {
  id         String   @id @default(uuid())
  name       String
  cities     String[]
  confidence Int      @default(0)
  nodeCount  Int      @default(0)
  edgeCount  Int      @default(0)
  status     String   @default("active")
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  investigations Investigation[]
  evidence       Evidence[]

  @@map("fraud_networks")
}

model Evidence {
  id              String       @id @default(uuid())
  type            EvidenceType
  value           String
  description     String?
  investigationId String?
  networkId       String?
  addedAt         DateTime     @default(now())

  investigation Investigation? @relation(fields: [investigationId], references: [id], onDelete: SetNull)
  network       FraudNetwork?  @relation(fields: [networkId], references: [id], onDelete: SetNull)

  @@index([type, value])
  @@index([investigationId])
  @@map("evidence")
}

// ─────────────────────────────────────────────────────────────────────
// SYSTEM
// ─────────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([entity, entityId])
  @@map("audit_logs")
}

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

// ─────────────────────────────────────────────────────────────────────
// AEGIS CONVERSATIONS
// ─────────────────────────────────────────────────────────────────────

model Conversation {
  id        String   @id @default(uuid())
  userId    String
  title     String   @default("New Chat")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId, updatedAt(sort: Desc)])
  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  role           String   // "user" | "assistant"
  content        String
  metadata       Json?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}
